# Spotify OAuth
CLIENT_ID=your-spotify-client-id
CLIENT_SECRET=your-spotify-client-secret
REDIRECT_URI=http://127.0.0.1:8080/auth/callback

# Database (MySQL)
DATABASE_CONNECTION_STRING=Server=localhost;Port=3306;Database=tracksbypopularity;User=root;Password=password;

# JWT Authentication
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_ISSUER=tracksByPopularity
JWT_AUDIENCE=tracksByPopularity
JWT_EXPIRY_DAYS=7

# Mailtrap (Email)
MAILTRAP_API_KEY=your-mailtrap-api-key
CLIENT_URL=http://localhost:5173

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USE_SSL=false
